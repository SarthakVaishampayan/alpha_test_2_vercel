# ─────────────────────────────────────────────────────────────────────────────
# StudyBuddy Frontend — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local for local development.
# NEVER commit your real .env.local file to version control.
#
# When deploying to Vercel, add these variables in:
#   Vercel Dashboard → Your Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# ── Backend API URL ───────────────────────────────────────────────────────────
# The base URL of your StudyBuddy backend (no trailing slash).
#
# Local development:
#   Point this to your locally running Express server.
VITE_API_URL=http://localhost:5000
#
# Production (set this in Vercel Dashboard, not here):
#   Point this to your deployed backend Vercel project URL.
#   Example: VITE_API_URL=https://studybuddy-backend.vercel.app
